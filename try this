import 'package:flutter/material.dart';

void main() {
  runApp(const MyApp());
}

class MyApp extends StatelessWidget {
  const MyApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Drawer Animation App',
      theme: ThemeData(
        primarySwatch: Colors.deepPurple,
      ),
      home: const HomePage(),
      debugShowCheckedModeBanner: false,
    );
  }
}

class HomePage extends StatefulWidget {
  const HomePage({super.key});

  @override
  State<HomePage> createState() => _HomePageState();
}

class _HomePageState extends State<HomePage> {
  String currentPage = "Home";

  void changePage(String page) {
    setState(() {
      currentPage = page;
    });
    Navigator.pop(context); // close drawer
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text(currentPage),
      ),

      // ===== DRAWER =====
      drawer: Drawer(
        child: ListView(
          children: [
            const DrawerHeader(
              decoration: BoxDecoration(color: Colors.deepPurple),
              child: Text(
                "Menu",
                style: TextStyle(color: Colors.white, fontSize: 24),
              ),
            ),
            ListTile(
              title: const Text("Home"),
              onTap: () => changePage("Home"),
            ),
            ListTile(
              title: const Text("Profile"),
              onTap: () => changePage("Profile"),
            ),
            ListTile(
              title: const Text("Messages"),
              onTap: () => changePage("Messages"),
            ),
            ListTile(
              title: const Text("Settings"),
              onTap: () => changePage("Settings"),
            ),
          ],
        ),
      ),

      // ===== BODY WITH BACKGROUND =====
      body: Container(
        decoration: const BoxDecoration(
          image: DecorationImage(
            image: AssetImage('assets/bgforeliflutter.jpg'),
            fit: BoxFit.cover,
          ),
        ),

        // ===== SIMPLE PAGE TRANSITION ANIMATION =====
        child: Center(
          child: AnimatedSwitcher(
            duration: const Duration(milliseconds: 500),

            child: Text(
              currentPage,
              key: ValueKey(currentPage), // IMPORTANT for animation
              style: const TextStyle(
                fontSize: 40,
                fontWeight: FontWeight.bold,
                color: Colors.white,
              ),
            ),
          ),
        ),
      ),
    );
  }
}
