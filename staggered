//////////////////////////////////////////////////
// MESSAGES PAGE (STAGGERED ANIMATION)
//////////////////////////////////////////////////

class MessagesPage extends StatefulWidget {
  const MessagesPage({super.key});

  @override
  State<MessagesPage> createState() => _MessagesPageState();
}

class _MessagesPageState extends State<MessagesPage> {
  List<bool> showItems = [false, false, false];

  @override
  void initState() {
    super.initState();
    startAnimation();
  }

  void startAnimation() async {
    for (int i = 0; i < showItems.length; i++) {
      await Future.delayed(const Duration(milliseconds: 300));
      setState(() {
        showItems[i] = true;
      });
    }
  }

  @override
  Widget build(BuildContext context) {
    List<String> messages = ["Hello!", "Welcome!", "Flutter is cool!"];

    return Center(
      child: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: List.generate(messages.length, (index) {
          return AnimatedOpacity(
            duration: const Duration(milliseconds: 500),
            opacity: showItems[index] ? 1 : 0,
            child: Padding(
              padding: const EdgeInsets.all(8),
              child: Text(messages[index], style: const TextStyle(fontSize: 18)),
            ),
          );
        }),
      ),
    );
  }
}

